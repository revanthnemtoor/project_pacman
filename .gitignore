# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# macOS
.DS_Store

# Logs
logs/*
!logs/.gitkeep

# Cache
cache/*
!cache/.gitkeep

# Staging
staging/*
!staging/.gitkeep

# Build Engine Exclusions (fromsource/)
fromsource/*-src/
fromsource/*-release/
fromsource/*/src/
fromsource/*/pkg/
fromsource/*.tar.gz
fromsource/*.tar.xz

# Package directories
packages/*
!packages/.gitkeep

new_packages/*
!new_packages/.gitkeep

# Repository data
repo/*
!repo/.gitkeep

# Build artifacts
build/
dist/
*.pkg.tar.*
*.src.tar.gz
!output/*.pkg.tar.zst
*.src.tar.gz

# Temporary files
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo

# Python cache
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE
.vscode/
.idea/