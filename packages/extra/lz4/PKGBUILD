pkgname=lz4
pkgver=1.10.0
pkgrel=1
pkgdesc="Extremely Fast Compression algorithm"

url="https://lz4.github.io/lz4/"
arch=(
    'darwin_arm64'
)
license=(
    'BSD-2-Clause'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}