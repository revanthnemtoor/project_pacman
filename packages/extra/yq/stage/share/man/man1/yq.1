owner\f[B]:\f[R]
  contact\f[B]:\f[R]
    name\f[B]:\f[R] Tom Preston\-Werner
    age\f[B]:\f[R] 36
  addresses\f[B]:\f[R]
    \f[B]\-\f[R] street\f[B]:\f[R] first street
