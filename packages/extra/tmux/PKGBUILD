pkgname=tmux
pkgver=3.7b
pkgrel=1
pkgdesc="Terminal multiplexer"

url="https://tmux.github.io/"
arch=(
    'darwin_arm64'
)
license=(
    'ISC'
)
depends=(
    'libevent'
    'utf8proc'
)
makedepends=(
    'pkgconf'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}