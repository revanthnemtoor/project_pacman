#libevent pkg-config source file

prefix=/opt/pacman/libevent/2.1.13
exec_prefix=${prefix}
libdir=/opt/pacman/libevent/2.1.13/lib
includedir=${prefix}/include

Name: libevent_openssl
Description: libevent_openssl adds openssl-based TLS support to libevent
Version: 2.1.13-stable
Requires: libevent
Conflicts:
Libs: -L${libdir} -levent_openssl
Libs.private:  -L/opt/pacman/openssl@3/3.6.3/lib -lssl -lcrypto   
Cflags: -I${includedir} -I/opt/pacman/openssl@3/3.6.3/include

