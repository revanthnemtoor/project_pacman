#libevent pkg-config source file

prefix=/opt/pacman/libevent/2.1.13
exec_prefix=${prefix}
libdir=/opt/pacman/libevent/2.1.13/lib
includedir=${prefix}/include

Name: libevent_pthreads
Description: libevent_pthreads adds pthreads-based threading support to libevent
Version: 2.1.13-stable
Requires: libevent
Conflicts:
Libs: -L${libdir} -levent_pthreads
Libs.private:  
Cflags: -I${includedir} -D_THREAD_SAFE 

