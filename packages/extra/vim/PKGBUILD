pkgname=vim
pkgver=9.2.0750
pkgrel=1
pkgdesc="Vi 'workalike' with many additional features"

url="https://www.vim.org/"
arch=(
    'darwin_arm64'
)
license=(
    'Vim'
)
depends=(
    'gettext'
    'libsodium'
)
makedepends=(
    'gettext'
    'lua'
    'python'
    'ruby'
)
checkdepends=(
    'lua'
    'python'
    'ruby'
)
conflicts=(
    'ex-vi'
    'macvim'
    'vim-classic'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}