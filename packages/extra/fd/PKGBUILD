pkgname=fd
pkgver=10.4.2
pkgrel=1
pkgdesc="Simple, fast and user-friendly alternative to find"

url="https://github.com/sharkdp/fd"
arch=(
    'darwin_arm64'
)
license=(
    'Apache-2.0 OR MIT'
)
makedepends=(
    'rust'
)
conflicts=(
    'fdclone'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}