pkgname=fzf
pkgver=0.74.0
pkgrel=1
pkgdesc="Command-line fuzzy finder written in Go"

url="https://junegunn.github.io/fzf/"
arch=(
    'darwin_arm64'
)
license=(
    'MIT'
)
makedepends=(
    'go'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}