pkgname=gettext
pkgver=1.0
pkgrel=1
pkgdesc="GNU internationalization (i18n) and localization (l10n) library"

url="https://www.gnu.org/software/gettext/"
arch=(
    'darwin_arm64'
)
license=(
    'GPL-3.0-or-later AND LGPL-2.1-or-later'
)
depends=(
    'json-c'
    'libunistring'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}