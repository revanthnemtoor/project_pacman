pkgname=oniguruma
pkgver=6.9.10
pkgrel=1
pkgdesc="Regular expressions library"

url="https://github.com/kkos/oniguruma/"
arch=(
    'darwin_arm64'
)
license=(
    'BSD-2-Clause'
)
makedepends=(
    'autoconf'
    'automake'
    'libtool'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}