pkgname=wget
pkgver=1.25.0
pkgrel=1
pkgdesc="Internet file retriever"

url="https://www.gnu.org/software/wget/"
arch=(
    'darwin_arm64'
)
license=(
    'GPL-3.0-or-later'
)
depends=(
    'gettext'
    'libidn2'
    'libpsl'
    'libunistring'
    'openssl'
)
makedepends=(
    'pkgconf'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}