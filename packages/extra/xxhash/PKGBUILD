pkgname=xxhash
pkgver=0.8.3
pkgrel=1
pkgdesc="Extremely fast non-cryptographic hash algorithm"

url="https://xxhash.com"
arch=(
    'darwin_arm64'
)
license=(
    'BSD-2-Clause AND GPL-2.0-or-later'
)
makedepends=(
    'cmake'
)
checkdepends=(
    'cmake'
)
options=('!strip')
source=()
sha256sums=()

package() {
    local _stage="$startdir/stage"
    local _dest="$pkgdir"
    mkdir -p "$_dest"

    local _dirs=(bin sbin lib lib64 include share etc var libexec)
    for _d in "${_dirs[@]}"; do
        if [ -d "$_stage/$_d" ]; then
            cp -a "$_stage/$_d" "$_dest/"
        fi
    done
}